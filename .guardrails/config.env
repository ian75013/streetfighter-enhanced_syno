# Guardrails configuration (copied into target repo as .guardrails/config.env)
# Space-separated list of files that must exist in the repository.
REQUIRED_DOCS="README.md"

# Enforce that every commit with code changes also includes a docs update.
# 1 = enabled, 0 = disabled
REQUIRE_DOC_UPDATE_ON_CODE_CHANGE=1

# Optional commands; leave empty to skip.
LINT_CMD=""
TEST_CMD=""
BUILD_CMD=""
